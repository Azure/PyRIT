      "docstring": {
        "text": "Registry for discovering and managing available initializers.\n\nThis class discovers all PyRITInitializer subclasses from the\npyrit/setup/initializers directory structure.\n\nInitializers are identified by their filename (e.g., \"objective_target\", \"simple\").\nThe directory structure is used for organization but not exposed to users."
      },
      "bases": [
        "BaseClassRegistry['PyRITInitializer', InitializerMetadata]"
      ],
