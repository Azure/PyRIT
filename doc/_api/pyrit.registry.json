          "docstring": {
            "text": "List metadata for all registered classes, optionally filtered.\n\nSupports filtering on any metadata property:\n- Simple types (str, int, bool): exact match\n- List types: checks if filter value is in the list",
            "params": [
              {
                "name": "include_filters",
                "type": "Optional[dict[str, object]]",
                "desc": "Optional dict of filters that items must match.\nKeys are metadata property names, values are the filter criteria.\nAll filters must match (AND logic).",
                "default": "None"
              },
              {
                "name": "exclude_filters",
                "type": "Optional[dict[str, object]]",
                "desc": "Optional dict of filters that items must NOT match.\nKeys are metadata property names, values are the filter criteria.\nAny matching filter excludes the item.",
