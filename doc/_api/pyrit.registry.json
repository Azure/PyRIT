              "name": "self",
              "kind": "positional or keyword"
            },
            {
              "name": "name",
              "type": "str",
              "kind": "positional or keyword"
            }
          ],
          "docstring": {
            "text": "Get a registered scorer instance by name.\n\nNote: This returns an already-instantiated scorer, not a class.",
            "params": [
              {
                "name": "name",
                "type": "str",
                "desc": "The registry name of the scorer.",
                "default": ""
              }
            ],
            "returns": [
              {
                "type": "Optional[Scorer]",
                "desc": "The scorer instance, or None if not found."
              }
            ]
          },
          "is_async": false,
          "returns_annotation": "Optional[Scorer]"
        },
        {
