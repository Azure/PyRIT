            },
            {
              "name": "max_attempts_on_failure",
              "type": "int",
              "desc": "Maximum number of attempts to retry on failure.",
              "default": "0"
            },
            {
              "name": "context_description_instructions_path",
              "type": "Optional[Path]",
              "desc": "Path to the context description\ninstructions YAML file. If not provided, uses the default path.",
