            "default": "0",
            "kind": "keyword-only"
          },
          {
            "name": "context_description_instructions_path",
            "type": "Optional[Path]",
            "default": "None",
            "kind": "keyword-only"
          },
          {
            "name": "affirmative_response",
            "type": "Optional[str]",
            "default": "None",
            "kind": "keyword-only"
          }
        ],
        "docstring": {
          "text": "Initialize the context compliance attack strategy.",
