          },
          {
            "name": "registered_class",
            "type": "type[T]",
            "kind": "keyword-only"
          },
          {
            "name": "factory",
            "type": "Optional[Callable[..., T]]",
            "default": "None",
            "kind": "keyword-only"
          },
          {
            "name": "default_kwargs",
            "type": "Optional[dict[str, object]]",
            "default": "None",
            "kind": "keyword-only"
          },
          {
            "name": "description",
            "type": "Optional[str]",
            "default": "None",
            "kind": "keyword-only"
          }
        ],
        "docstring": {
          "text": "Initialize a class entry.",
          "params": [
            {
              "name": "registered_class",
              "type": "type[T]",
              "desc": "The actual Python class (Type[T]).",
              "default": ""
