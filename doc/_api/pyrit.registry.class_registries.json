        "returns_annotation": "None"
      }
    },
    {
      "name": "ClassEntry",
      "kind": "class",
      "docstring": {
        "text": "Internal wrapper for a registered class.\n\nThis holds the class itself (Type[T]) along with optional factory\nand default parameters for creating instances.\n\nNote: This is an internal implementation detail. Users interact with\nregistries via get_class(), create_instance(), and list_metadata()."
      },
      "bases": [
        "Generic[T]"
      ],
      "methods": [
