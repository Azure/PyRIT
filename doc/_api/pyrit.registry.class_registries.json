              "name": "self",
              "kind": "positional or keyword"
            },
            {
              "name": "kwargs",
              "type": "object",
              "default": "{}",
              "kind": "variadic keyword"
            }
          ],
          "docstring": {
            "text": "Create an instance of the registered class.",
            "params": [
              {
                "name": "**kwargs",
                "type": "object",
                "desc": "Additional keyword arguments. These override default_kwargs.",
                "default": "{}"
              }
            ],
            "returns": [
              {
                "type": "T",
                "desc": "An instance of type T."
              }
            ]
          },
          "is_async": false,
          "returns_annotation": "T"
        }
      ],
      "attributes": [
        {
          "name": "default_kwargs"
