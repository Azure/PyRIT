          "name": "discover_user_scenarios",
          "kind": "function",
          "signature": [
            {
              "name": "self",
              "kind": "positional or keyword"
            }
          ],
          "docstring": {
            "text": "Discover user-defined scenarios from global variables.\n\nAfter initialization scripts are executed, they may define Scenario subclasses\nand store them in globals. This method searches for such classes.\n\nUser scenarios will override built-in scenarios with the same name."
          },
          "is_async": false,
          "returns_annotation": "None"
        },
        {
          "name": "get_registry_singleton",
          "kind": "function",
          "signature": [
            {
              "name": "cls",
              "kind": "positional or keyword"
            }
          ],
