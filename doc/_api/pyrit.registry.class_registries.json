          "docstring": {
            "text": "Get the singleton instance of the InitializerRegistry.",
            "returns": [
              {
                "type": "InitializerRegistry",
                "desc": "The singleton InitializerRegistry instance."
              }
            ]
          },
          "is_async": false,
          "returns_annotation": "InitializerRegistry"
        },
