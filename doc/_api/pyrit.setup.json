      "name": "ConfigurationLoader",
      "kind": "class",
      "docstring": {
        "text": "Loader for PyRIT configuration from YAML files.\n\nThis class loads configuration from a YAML file and provides methods to\ninitialize PyRIT with the loaded configuration."
