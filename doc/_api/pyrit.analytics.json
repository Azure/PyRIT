          "signature": [
            {
              "name": "self",
              "kind": "positional or keyword"
            },
            {
              "name": "chat_message_content",
              "type": "str",
              "kind": "keyword-only"
            }
          ],
          "docstring": {
            "text": "Retrieve chat messages that have the same converted content.",
            "params": [
              {
                "name": "chat_message_content",
                "type": "str",
                "desc": "The content of the chat message to find similar messages for.",
                "default": ""
              }
            ],
            "returns": [
              {
                "type": "list[ConversationMessageWithSimilarity]",
                "desc": "list[ConversationMessageWithSimilarity]: A list of ConversationMessageWithSimilarity objects representing"
