              "default": ""
            },
            {
              "name": "prompt_normalizer",
              "type": "Optional[PromptNormalizer]",
              "desc": "Optional prompt normalizer for converting prompts.\nIf not provided, a default PromptNormalizer instance will be created.",
              "default": "None"
            }
          ]
        },
        "is_async": false
      }
    },
