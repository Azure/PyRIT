          "docstring": {
            "text": "Set or update the system prompt for a conversation.",
            "params": [
              {
                "name": "target",
                "type": "PromptChatTarget",
                "desc": "The chat target to set the system prompt on.",
                "default": ""
              },
              {
                "name": "conversation_id",
                "type": "str",
                "desc": "Unique identifier for the conversation.",
                "default": ""
              },
              {
                "name": "system_prompt",
