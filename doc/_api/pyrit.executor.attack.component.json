                "desc": "The system prompt text.",
                "default": ""
              },
              {
                "name": "labels",
                "type": "Optional[dict[str, str]]",
                "desc": "Optional labels to associate with the system prompt.",
                "default": "None"
              }
            ]
          },
          "is_async": false,
          "returns_annotation": "None"
        }
      ],
