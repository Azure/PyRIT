      ],
      "docstring": {
        "text": "Apply retry logic with exponential backoff to a function.\n\nRetries the function if the result of the retry_function is True,\nwith a wait time between retries that follows an exponential backoff strategy.\nLogs retry attempts at the INFO level and stops after a maximum number of attempts.",
        "params": [
          {
            "name": "retry_function",
            "type": "Callable",
            "desc": "The boolean function to determine if a retry should occur based\non the result of the decorated function.",
            "default": ""
          },
          {
            "name": "retry_max_num_attempts",
            "type": "(Optional, int)",
            "desc": "The maximum number of retry attempts. Defaults to\nenvironment variable CUSTOM_RESULT_RETRY_MAX_NUM_ATTEMPTS or 10.",
            "default": "None"
          }
        ],
        "returns": [
          {
            "type": "Callable[..., Any]",
            "desc": "The decorated function with retry logic applied."
          }
        ]
      },
      "is_async": false,
      "returns_annotation": "Callable[..., Any]"
    },
