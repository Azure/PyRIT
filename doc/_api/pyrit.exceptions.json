    {
      "name": "ExecutionContextManager",
      "kind": "class",
      "docstring": {
        "text": "A context manager for setting execution context during component operations.\n\nThis class provides a convenient way to set and automatically clear\nexecution context when entering and exiting a code block.\n\nOn successful exit, the context is restored to its previous value.\nOn exception, the context is preserved so exception handlers can access it."
      },
      "attributes": [
        {
          "name": "context",
          "type": "ExecutionContext"
        }
      ],
