              "kind": "positional or keyword"
            },
            {
              "name": "result",
              "type": "ScenarioResult",
              "kind": "positional or keyword"
            }
          ],
          "docstring": {
            "text": "Print a summary of the scenario result with per-strategy breakdown.\n\nDisplays:\n- Scenario identification (name, version, PyRIT version)\n- Target and scorer information\n- Overall statistics\n- Per-strategy success rates and result counts",
            "params": [
              {
                "name": "result",
                "type": "ScenarioResult",
                "desc": "The scenario result to summarize",
                "default": ""
              }
            ]
          },
          "is_async": false,
