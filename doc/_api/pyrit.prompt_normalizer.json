          "name": "conversation_id",
          "type": "str | None"
        },
        {
          "name": "message",
          "type": "Message"
        },
        {
          "name": "request_converter_configurations",
          "type": "list[PromptConverterConfiguration]"
        },
        {
          "name": "response_converter_configurations",
          "type": "list[PromptConverterConfiguration]"
        }
      ],
      "init": {
        "name": "__init__",
        "kind": "function",
        "signature": [
          {
            "name": "self",
