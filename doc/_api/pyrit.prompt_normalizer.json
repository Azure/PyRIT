          "text": "Initialize a normalizer request.",
          "params": [
            {
              "name": "message",
              "type": "Message",
              "desc": "The message to be normalized.",
              "default": ""
            },
            {
              "name": "request_converter_configurations",
              "type": "list[PromptConverterConfiguration]",
              "desc": "Configurations for converting\nthe request. Defaults to an empty list.",
              "default": "None"
            },
            {
              "name": "response_converter_configurations",
              "type": "list[PromptConverterConfiguration]",
              "desc": "Configurations for converting\nthe response. Defaults to an empty list.",
              "default": "None"
            },
            {
              "name": "conversation_id",
              "type": "Optional[str]",
              "desc": "The ID of the conversation. Defaults to None.",
              "default": "None"
