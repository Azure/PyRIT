{
  "name": "pyrit.prompt_normalizer",
  "kind": "module",
  "docstring": {
    "text": "Prompt normalization components for standardizing and converting prompts.\n\nThis module provides tools for normalizing prompts before sending them to targets,\nincluding converter configurations and request handling."
  },
  "members": [
