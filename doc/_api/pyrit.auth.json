    {
      "name": "TokenProviderCredential",
      "kind": "class",
      "docstring": {
        "text": "Wrapper to convert a token provider callable into an Azure TokenCredential.\n\nThis class bridges the gap between token provider functions (like those returned by\nget_azure_token_provider) and Azure SDK clients that require a TokenCredential object."
      },
      "methods": [
        {
          "name": "get_token",
          "kind": "function",
          "signature": [
            {
              "name": "self",
              "kind": "positional or keyword"
            },
            {
              "name": "scopes",
              "type": "str",
              "default": "()",
              "kind": "variadic positional"
            },
            {
              "name": "kwargs",
              "type": "Any",
              "default": "{}",
              "kind": "variadic keyword"
            }
          ],
          "docstring": {
            "text": "Get an access token.",
            "params": [
              {
                "name": "scopes",
                "type": "str",
                "desc": "Token scopes (ignored as the scope is already configured in the token provider).",
                "default": "()"
              },
              {
                "name": "kwargs",
                "type": "Any",
                "desc": "Additional arguments (ignored).",
                "default": "{}"
              }
            ],
            "returns": [
              {
                "type": "AccessToken",
                "desc": "The access token with expiration time."
              }
            ]
          },
          "is_async": false,
          "returns_annotation": "AccessToken"
        }
      ],
      "init": {
        "name": "__init__",
        "kind": "function",
        "signature": [
          {
            "name": "self",
            "kind": "positional or keyword"
          },
          {
